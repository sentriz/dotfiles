#!/usr/bin/env bash

why="menu-system: lid stay awake"

lid_kept_awake() {
    systemd-inhibit --list 2>/dev/null | grep -q "$why"
}

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r id _ <<<"$1"
    case "$id" in
    suspend) systemctl suspend ;;
    hibernate) systemctl hibernate ;;
    reboot) systemctl reboot ;;
    shutdown) systemctl poweroff ;;
    lid)
        if lid_kept_awake; then
            pkill -f "$why"
            while lid_kept_awake; do sleep 0.1; done
        else
            systemd-inhibit --what=handle-lid-switch --why="$why" sleep infinity &
            disown
            while ! lid_kept_awake; do sleep 0.1; done
        fi
        ;;
    esac
    exit
fi

highlight="$(cmenu highlight)"
stay="$(cmenu stay)"

lid_pre="$stay"
lid_kept_awake && lid_pre="$stay$highlight"

printf '%s\t%s\n' \
    suspend "to ram" \
    hibernate "to disk" \
    reboot "the machine" \
    shutdown "the machine"
printf '%s%s\t%s\n' "$lid_pre" lid "stay awake when closed"
