#!/usr/bin/env bash

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r id _ <<<"$1"
    case "$id" in
    suspend) systemctl suspend ;;
    hibernate) systemctl hibernate ;;
    reboot) systemctl reboot ;;
    shutdown) systemctl poweroff ;;
    esac
    exit 0
fi

printf '%s\t%s\n' \
    suspend "to ram" \
    hibernate "to disk" \
    reboot "the machine" \
    shutdown "the machine"
