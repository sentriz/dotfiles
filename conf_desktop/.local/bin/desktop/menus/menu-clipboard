#!/usr/bin/env bash

if [[ "$CMENU_MODE" = "preview" ]]; then
    row="$1"
    if grep -vqP '^\d+\t\[\[ binary data .* \]\]' <<<"$row"; then
        cliphist decode <<<"$row"
    else
        format="$(grep -oP '\S+(?= \d+x\d+ \]\])' <<<"$row")"
        [[ "$format" == "png" ]] || exit 0
        cliphist decode <<<"$row" | cmenu image -
    fi
    exit 0
fi

if [[ "$#" -gt 0 ]]; then
    cliphist decode <<<"$1" | wl-copy
    exit
fi

highlight="$(cmenu highlight)"

mapfile -t rows < <(cliphist list)
[[ "${#rows[@]}" -eq 0 ]] && exit 0

if cmp -s <(cliphist decode <<<"${rows[0]}") <(wl-paste -n 2>/dev/null); then
    rows[0]="$highlight${rows[0]}"
fi

printf '%s\n' "${rows[@]}"
