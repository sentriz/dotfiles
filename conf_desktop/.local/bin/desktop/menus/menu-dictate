#!/usr/bin/env bash

out="$XDG_RUNTIME_DIR/menu-dictate"
pidfile="$XDG_RUNTIME_DIR/menu-dictate.pid"

read -r pid <"$pidfile" 2>/dev/null
if [[ -n "$pid" ]] && ! kill -0 "$pid" 2>/dev/null; then
    pid=""
    rm -f "$pidfile"
fi

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r id _ <<<"$1"
    case "$id" in
    record)
        [[ -n "$pid" ]] && exit 0
        rm -f "$out"
        dictate >"$out" 2>/dev/null &
        echo $! >"$pidfile"
        disown
        ;;
    stop)
        [[ -n "$pid" ]] && kill "$pid" 2>/dev/null
        while kill -0 "$pid" 2>/dev/null; do sleep 0.1; done
        rm -f "$pidfile"
        sed -zi 's/^[[:space:]]*//; s/[[:space:]]*$//' "$out"
        ;;
    copy) wl-copy <"$out" && rm -f "$out" ;;
    esac
    exit
fi

stay="$(cmenu stay)"

if [[ -n "$pid" ]]; then
    printf '%s%s\t%s\n' "$stay" stop "recording"
elif [[ -s "$out" ]]; then
    printf '%s%s\n' "$(cmenu label)" "$(tr '\n' ' ' <"$out")"
    printf '%s\t%s\n' copy "to clipboard"
    printf '%s%s\t%s\n' "$stay" record "again"
else
    printf '%s%s\t%s\n' "$stay" record "from the mic"
fi
