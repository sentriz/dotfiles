#!/usr/bin/env bash

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r id _ <<<"$1"
    case "$id" in
    add) timer +60 ;;
    remove) timer -60 ;;
    clear) timer clear ;;
    esac
    block-up timer
    exit
fi

left="$(timer)"
[[ -n "$left" ]] && printf '%s%dm%02ds left\n' "$(cmenu label)" "$((left / 60))" "$((left % 60))"

printf '%s\t%s\n' \
    add "a minute" \
    remove "a minute" \
    clear "the timer"
