#!/usr/bin/env bash

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r id _ <<<"$1"
    case "$id" in
    add) timer +60 ;;
    remove) timer -60 ;;
    clear) timer clear ;;
    esac
    block-up timer
    exit 0
fi

printf '%s\t%s\n' \
    add "a minute" \
    remove "a minute" \
    clear "the timer"
