#!/usr/bin/env bash

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r name hash id <<<"$1"
    case "$name" in
    "input")
        wl-copy -n <<<"$id"
        ;;
    *)
        wl-copy -n <<<"$hash"
        ;;
    esac

    exit
fi

inp="$CMENU_INPUT"
if [[ -z "$inp" ]]; then
    inp="$(wl-paste -n)"
fi
if [[ -z "$inp" ]]; then
    echo "$(cmenu label)no input"
    exit
fi

if [[ "$inp" =~ ^[0-9]+$ ]]; then
    hiphash -enc all "$inp" || exit 0
fi

hiphash "$inp" || exit 0
