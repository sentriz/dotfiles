#!/usr/bin/env bash

pidfile="$XDG_RUNTIME_DIR/menu-radio.pid"

if [[ "$CMENU_MODE" = "preview" ]]; then
    url="$(rsl ini json <"$RADIO_DIR/$1" | jq -r '.playlist.File1')"
    info="$(
        timeout 8 \
            ffprobe \
            -v error \
            -hide_banner \
            -show_entries 'format=format_name:format_tags:stream=index,codec_name,sample_rate,channels,channel_layout,bit_rate' \
            -of json \
            "$url" 2>/dev/null \
            | jq -r '
                (.streams[] | .index as $i | to_entries[] | select(.key != "index") | "\($i).\(.key | ascii_downcase)\t\(.value)"),
                (.format.format_name | "format_name\t\(.)"),
                (.format.tags // {} | to_entries[] | "\(.key | ascii_downcase)\t\(.value)")
            ' 2>/dev/null
    )"
    [[ -z "$info" ]] && info=$'status\toffline'

    printf '%s\n' "$info" | table
    exit 0
fi

IFS=$'\t' read -r current_pid current_station <"$pidfile" 2>/dev/null
if [[ -n "$current_pid" ]] && ! kill -0 "$current_pid" 2>/dev/null; then
    current_pid=""
    current_station=""
    rm -f "$pidfile"
fi

if [[ "$#" -gt 0 ]]; then
    if [[ "$current_pid" -gt 0 ]]; then
        kill "$current_pid" 2>/dev/null
        while kill -0 "$current_pid" 2>/dev/null; do sleep 0.1; done
    fi

    station="$1"

    if [[ "$station" = "$current_station" ]]; then
        rm -f "$pidfile"
        exit
    fi

    mpv \
        --no-ytdl \
        --no-video \
        --no-cache \
        --quiet \
        --force-media-title="$station" \
        --no-resume-playback \
        "$RADIO_DIR/$station" &
    echo -e "$!\t$station" >"$pidfile"
    notify-send 'started radio station' "$station"

    exit
fi

highlight="$(cmenu highlight)"

find \
    "$RADIO_DIR" \
    -maxdepth 1 \
    -not -name '.st*' \
    -type f \
    -printf "%f\n" | while read -r line; do
    pre=""
    [[ "$line" = "$current_station" ]] && pre="$highlight"
    printf '%s%s\n' "$pre" "$line"
done
