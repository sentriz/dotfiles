#!/usr/bin/env bash

pidfile="$XDG_RUNTIME_DIR/menu-radio.pid"

IFS=$'\t' read -r current_pid current_station <"$pidfile" 2>/dev/null
if [[ -n "$current_pid" ]] && ! kill -0 "$current_pid" 2>/dev/null; then
    current_pid=""
    current_station=""
    rm -f "$pidfile"
fi

if [[ "$#" -gt 0 ]]; then
    if [[ "$current_pid" -gt 0 ]]; then
        kill "$current_pid" 2>/dev/null
        while kill -0 "$current_pid" 2>/dev/null; do sleep 0.1; done
    fi

    station="$1"

    if [[ "$station" = "$current_station" ]]; then
        rm -f "$pidfile"
        exit
    fi

    mpv \
        --no-ytdl \
        --no-video \
        --no-cache \
        --quiet \
        --force-media-title="$station" \
        --no-resume-playback \
        "$RADIO_DIR/$station" &
    echo -e "$!\t$station" >"$pidfile"
    notify-send 'started radio station' "$station"

    exit
fi

highlight="$(cmenu highlight)"

find \
    "$RADIO_DIR" \
    -maxdepth 1 \
    -not -name '.st*' \
    -type f \
    -printf "%f\n" | while read -r line; do
    pre=""
    [[ "$line" = "$current_station" ]] && pre="$highlight"
    printf '%s%s\n' "$pre" "$line"
done
