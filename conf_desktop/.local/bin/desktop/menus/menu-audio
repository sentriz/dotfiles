#!/usr/bin/env bash

if [[ "$CMENU_MODE" = "preview" ]]; then
    IFS=$'\t' read -r _ id _ <<<"$1"
    {
        wpctl get-volume "$id" 2>/dev/null | sed -E 's/: /\t/'
        wpctl inspect "$id" 2>/dev/null | sed -nE \
            's/^[ *]*(node\.description|device\.api|api\.bluez5\.codec|api\.bluez5\.profile) = "(.+)"$/\1\t\2/p'
        pw-dump | jq -r --argjson id "$id" '
            .[] | select(.id == $id) | .info |
            ("state\t\(.state)"),
            (.params.Format[0]? | select(.) | "format\t\(.format) \(.rate)Hz \(.channels)ch")'
    } | lower | table
    exit 0
fi

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r _ id _ <<<"$1"
    wpctl set-default "$id"
    exit
fi

default_sink="$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -Po "^id \K[0-9]+")"
default_source="$(wpctl inspect @DEFAULT_AUDIO_SOURCE@ 2>/dev/null | grep -Po "^id \K[0-9]+")"

highlight="$(cmenu highlight)"

pw-dump \
    | jq -r \
        --argjson defaults "[$default_sink, $default_source]" \
        --arg highlight "$highlight" \
        '[.[] | select((.info.props["media.class"] // "") | test("^Audio/(Sink|Source)$"))] | sort_by(.info.props["media.class"]) | .[] | "\(if .id | IN($defaults[]) then $highlight else "" end)\(.info.props["media.class"])\t\(.id)\t\(.info.props["node.description"])"' \
    | lower
