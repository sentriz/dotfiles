#!/usr/bin/env bash

if [[ "$#" -gt 0 ]]; then
    IFS=$'\t' read -r cmd arg <<<"$1"

    case "$cmd" in
    "screenshot")
        filename="${SCREENSHOTS_DIR}/$(date '+%Y%m%d_%H%M%S').png"

        {
            area_out="$(area "$arg")"
            [[ -z "$area_out" ]] && exit 1

            toplevel="$(grep -Po '^toplevel\t\K.+' <<<"$area_out")"
            geo="$(grep -Po '^geo\t\K.+' <<<"$area_out")"

            if [[ -n "$toplevel" ]]; then
                grim -T "$toplevel" "$filename"
            elif [[ -n "$geo" ]]; then
                grim -g "$geo" "$filename"
            else
                exit 1
            fi
            [[ ! -f "$filename" ]] && exit 1

            wl-copy <"$filename"

            notify-send "screenshot" "$filename"
        } &
        disown
        ;;

    "recording" | "recording audio")
        filename="${RECORDINGS_DIR}/$(date '+%Y%m%d_%H%M%S').mp4"

        extra_args=()
        if [[ "$cmd" = "recording audio" ]]; then
            default_sink="$(wpctl inspect @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -Po 'node\.name = "\K[^"]+')"
            extra_args=(--audio="${default_sink}.monitor")
        fi

        {
            area_out="$(area "$arg")"
            geo="$(grep -Po '^geo\t\K.+' <<<"$area_out")"
            [[ -z "$geo" ]] && exit 1

            wf-recorder "${extra_args[@]}" -f "$filename" -g "$geo" -x yuv420p >/dev/null
            [[ ! -f "$filename" ]] && exit 1

            wl-copy -t text/uri-list "file://$filename"

            notify-send "recorded" "$filename"
        } &
        disown
        ;;

    "recording stop")
        killall --signal SIGINT wf-recorder
        while pidof -q wf-recorder; do sleep 0.1; done
        ;;
    esac

    exit
fi

recording=false
if pidof -q wf-recorder; then
    recording=true
fi

for type in "screenshot" "recording" "recording audio"; do
    if [[ "$recording" = true && "$type" =~ "recording" ]]; then
        continue
    fi

    for area in $(area list); do
        printf '%s\t%s\n' "$type" "$area"
    done
done

if [[ "$recording" = true ]]; then
    printf '%s\n' "recording stop"
fi
