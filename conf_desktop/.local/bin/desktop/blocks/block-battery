#!/usr/bin/env bash

acpi_out="$(acpi -b 2>/dev/null | head -1)"
[[ -z "$acpi_out" ]] && exit

batt_level="$(echo "$acpi_out" | grep -oP '[0-9]+(?=%)')"
[[ -z "$batt_level" ]] && exit
[[ "$batt_level" -ge "100" ]] && exit

status="battery"
if echo "$acpi_out" | grep -iq "\bcharging"; then
    status="charging"
fi

warning=""
if [[ "$status" = "battery" && "$batt_level" -le "10" ]]; then
    beep 1 &
    disown
    warning=" ⚠"
fi

echo "$status ${batt_level}%$warning"
