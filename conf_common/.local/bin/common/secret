#!/usr/bin/env bash

case "$1" in
write)
    key=$2
    value=$3

    tmp=$(mktemp)
    trap 'rm -f "$tmp"' EXIT
    printf '\n%s\n' "$value" >"$tmp"

    EDITOR="cp $tmp" rbw add --folder dotfiles "secret $key" 2>/dev/null \
        || EDITOR="cp $tmp" rbw edit --folder dotfiles "secret $key"
    ;;
*)
    rbw get --folder dotfiles --field notes "secret $1" 2>/dev/null
    ;;
esac
